<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.blog.mapper.TagMapper">

    <select id="selectAll" resultType="com.example.blog.entity.Tag">
        select
            id,
            name,
            create_time,
            update_time
        from tag
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.blog.entity.Tag">
        select
            id,
            name,
            create_time,
            update_time
        from tag
        where id = #{id}
        limit 1
    </select>

    <select id="selectByName" resultType="com.example.blog.entity.Tag">
        select
            id,
            name,
            create_time,
            update_time
        from tag
        where name = #{name}
        limit 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into tag (
            name
        ) values (
            #{name}
        )
    </insert>

    <update id="updateById">
        update tag
        set name = #{name}
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from tag
        where id = #{id}
    </delete>

    <delete id="deleteArticleRelationByTagId">
        delete from article_tag
        where tag_id = #{tagId}
    </delete>

    <select id="selectByArticleId" resultType="com.example.blog.vo.TagVO">
        select
            t.id,
            t.name
        from tag t
        inner join article_tag at on t.id = at.tag_id
        where at.article_id = #{articleId}
        order by t.id asc
    </select>

    <select id="selectByIds" resultType="com.example.blog.vo.TagVO">
        select
            id,
            name
        from tag
        where id in
        <foreach collection="tagIds" item="tagId" open="(" separator="," close=")">
            #{tagId}
        </foreach>
        order by id asc
    </select>

    <select id="countAll" resultType="long">
        select count(1)
        from tag
    </select>
</mapper>
